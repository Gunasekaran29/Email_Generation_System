{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,

    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",

    "skipLibCheck": true,

    /* 🔥 IMPORTANT FIX */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "jsx": "react-jsx",

    "types": ["vite/client"]
  },
  "include": ["src"]
}